---
config:
  layout: elk
  elk:
    direction: RIGHT
    nodePlacementStrategy: BRANDES_KOEPF
    spacing.nodeNode: 100
    spacing.componentComponent: 150
---
graph LR

    classDef screen fill:#f9f,stroke:#333,stroke-width:3px;
    classDef hook fill:#bbf,stroke:#333,stroke-width:2px;
    classDef service fill:#bfb,stroke:#333,stroke-width:2px;
    classDef utils fill:#fff,stroke:#333,stroke-dasharray: 5 5;
    
  subgraph app__MainApp_ ["app/(MainApp)"]
    app__MainApp__ChatGroupMesh["app/(MainApp)/ChatGroupMesh"]:::screen
    app__MainApp__ChatOneToOne["app/(MainApp)/ChatOneToOne"]:::screen
    app__MainApp__Home["app/(MainApp)/Home"]:::screen
    app__MainApp__Profile["app/(MainApp)/Profile"]:::screen
    app__MainApp___layout["app/(MainApp)/_layout"]:::screen
  end
  subgraph app__auth_ ["app/(auth)"]
    app__auth__EnterPin["app/(auth)/EnterPin"]:::screen
    app__auth__ForgotPassword["app/(auth)/ForgotPassword"]:::screen
    app__auth__Login["app/(auth)/Login"]:::screen
    app__auth__Signup["app/(auth)/Signup"]:::screen
    app__auth___layout["app/(auth)/_layout"]:::screen
  end
  subgraph app ["app"]
    app__layout["app/_layout"]:::screen
    app_index["app/index"]:::screen
  end
  subgraph components_auth ["components/auth"]
    components_auth_AuthLayout["components/auth/AuthLayout"]
    components_auth_AuthUI["components/auth/AuthUI"]
  end
  subgraph hooks ["hooks"]
    hooks_SocketContext["hooks/SocketContext"]:::hook
    hooks_UserDataContext["hooks/UserDataContext"]:::hook
    hooks_useAuth["hooks/useAuth"]:::hook
    hooks_useAuthSubmit["hooks/useAuthSubmit"]:::hook
    hooks_useChatroom["hooks/useChatroom"]:::hook
    hooks_useNotification["hooks/useNotification"]:::hook
    hooks_useWebRTC["hooks/useWebRTC"]:::hook
  end
  subgraph hooks_WebRTC ["hooks/WebRTC"]
    hooks_WebRTC_useDataChannel["hooks/WebRTC/useDataChannel"]:::hook
    hooks_WebRTC_useMediaStream["hooks/WebRTC/useMediaStream"]:::hook
    hooks_WebRTC_usePeerConnection["hooks/WebRTC/usePeerConnection"]:::hook
  end
  subgraph services ["services"]
    services_api["services/api"]:::service
  end
  subgraph services_crypto ["services/crypto"]
    services_crypto_secureStorage["services/crypto/secureStorage"]:::service
  end
  subgraph utils ["utils"]
    utils_ToastConfig["utils/ToastConfig"]:::utils
    utils_apiErrorHandler["utils/apiErrorHandler"]:::utils
    utils_webrtc["utils/webrtc"]:::utils
  end
